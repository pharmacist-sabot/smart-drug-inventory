{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnePharm",
  "version": "0.1.0",
  "identifier": "com.onepharm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OnePharm — ระบบประเมินประสิทธิภาพคลังยา",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "center": true,
        "visible": true,
        "focus": true,
        "shadow": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "windowEffects": {
          "effects": [],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "rxdevman",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
